# Database
DATABASE_URL=postgres://user:password@localhost:5432/insighta

# Server
PORT=3000
NODE_ENV=development

# OAuth 2.0 (GitHub)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback
GITHUB_OAUTH_URL=https://github.com/login/oauth
GITHUB_API_URL=https://api.github.com

# JWT Secrets
JWT_ACCESS_SECRET=your_super_secret_access_token_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CSV Export
MAX_CSV_ROWS=50000
